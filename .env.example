APP_MODE=local
DATABASE_URL=postgresql+psycopg://agentforge:agentforge@postgres:5432/agentforge
REDIS_URL=redis://redis:6379/0
QUEUE_NAME=agentforge-runs
QUEUE_EXECUTION_MODE=redis
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# LLM provider. API keys stay backend-only and are never returned to the frontend.
LLM_PROVIDER=openai_compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://ollama:11434
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200
MAX_STEPS_PER_RUN=32
MAX_COST_PER_RUN_USD=1.0

# Optional external search bridge. When empty, web_search reports disabled.
WEB_SEARCH_ENDPOINT=
MAX_UPLOAD_MB=10
JWT_SECRET=change-me-for-local-dev
METRICS_ENABLED=true
